@startuml Backend Architecture
!theme plain

package "Infrastructure Layer" {
  [REST Controllers]
  [JPA Repositories]
  [Security Config]
  [Database]
}

package "Application Layer" {
  [Tournament Service]
  [User Service]
  [Ticket Service]
  [Auth Service]
}

package "Domain Layer" {
  [Tournament Entity]
  [User Entity]
  [Ticket Entity]
  [Business Rules]
}

[REST Controllers] --> [Tournament Service]
[REST Controllers] --> [User Service]
[REST Controllers] --> [Ticket Service]
[REST Controllers] --> [Auth Service]

[Tournament Service] --> [Tournament Entity]
[User Service] --> [User Entity]
[Ticket Service] --> [Ticket Entity]

[JPA Repositories] --> [Database]
[Tournament Service] --> [JPA Repositories]
[User Service] --> [JPA Repositories]
[Ticket Service] --> [JPA Repositories]

@enduml