# Variables de entorno para CI/CD Pipeline
# Backend Torneos

## GitHub Actions Secrets
# Configurar en: Settings > Secrets and variables > Actions

DOCKER_USERNAME=<tu-usuario-docker-hub>
DOCKER_PASSWORD=<tu-password-docker-hub>

## GitLab CI/CD Variables
# Configurar en: Settings > CI/CD > Variables

CI_REGISTRY=registry.gitlab.com
CI_REGISTRY_USER=<tu-usuario-gitlab>
CI_REGISTRY_PASSWORD=<tu-token-gitlab>
CI_REGISTRY_IMAGE=registry.gitlab.com/<tu-usuario>/<tu-proyecto>

## Opcional: Variables adicionales

# Base de datos para tests
DB_HOST=localhost
DB_PORT=5432
DB_NAME=testdb
DB_USER=test
DB_PASSWORD=test

# JWT Secret para tests
JWT_SECRET=test-secret-key-for-ci-cd-pipeline

# Spring Profile
SPRING_PROFILES_ACTIVE=test
